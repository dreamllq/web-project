import { Test, TestingModule } from '@nestjs/testing';
import { describe, it, expect, beforeEach, afterEach } from 'bun:test';
import { OAuthSecretEncryptionService } from './oauth-secret-encryption.service';

describe('OAuthSecretEncryptionService', () => {
  let service: OAuthSecretEncryptionService;

  // Valid 32-byte hex string (64 hex characters)
  const VALID_ENCRYPTION_KEY = '0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef';
  const INVALID_KEY_SHORT = '0123456789abcdef'; // Too short
  const INVALID_KEY_NON_HEX = 'gghhiijjkkllmmnnooppqqrrssttuuvvwwxxyyzzzzaabbccddeeffgghhiijj'; // Non-hex characters

  describe('with valid encryption key', () => {
    beforeEach(async () => {
      process.env.OAUTH_SECRET_ENCRYPTION_KEY = VALID_ENCRYPTION_KEY;

      const module: TestingModule = await Test.createTestingModule({
        providers: [OAuthSecretEncryptionService],
      }).compile();

      service = module.get<OAuthSecretEncryptionService>(OAuthSecretEncryptionService);
      await service.onModuleInit();
    });

    afterEach(() => {
      delete process.env.OAUTH_SECRET_ENCRYPTION_KEY;
    });

    describe('encrypt', () => {
      it('should encrypt plaintext and return hex string in format iv:ciphertext:auth_tag', () => {
        const plaintext = 'my-secret-client-secret-12345';
        const encrypted = service.encrypt(plaintext);

        // Should return a string with 3 parts separated by colons
        expect(typeof encrypted).toBe('string');
        const parts = encrypted.split(':');
        expect(parts).toHaveLength(3);

        // All parts should be valid hex strings
        const [iv, ciphertext, authTag] = parts;
        expect(iv).toMatch(/^[0-9a-f]+$/);
        expect(ciphertext).toMatch(/^[0-9a-f]+$/);
        expect(authTag).toMatch(/^[0-9a-f]+$/);

        // IV should be 12 bytes (24 hex characters) for AES-256-GCM
        expect(iv).toHaveLength(24);

        // Auth tag should be 16 bytes (32 hex characters) for GCM mode
        expect(authTag).toHaveLength(32);
      });

      it('should produce different ciphertext for same plaintext (random IV)', () => {
        const plaintext = 'my-secret';
        const encrypted1 = service.encrypt(plaintext);
        const encrypted2 = service.encrypt(plaintext);

        // Different IVs should produce different ciphertexts
        expect(encrypted1).not.toBe(encrypted2);
      });

      it('should handle empty string', () => {
        const plaintext = '';
        const encrypted = service.encrypt(plaintext);

        expect(typeof encrypted).toBe('string');
        const parts = encrypted.split(':');
        expect(parts).toHaveLength(3);
      });

      it('should handle long strings', () => {
        const plaintext = 'a'.repeat(1000);
        const encrypted = service.encrypt(plaintext);

        expect(typeof encrypted).toBe('string');
        const parts = encrypted.split(':');
        expect(parts).toHaveLength(3);
      });
    });

    describe('decrypt', () => {
      it('should decrypt ciphertext back to original plaintext', () => {
        const plaintext = 'my-secret-client-secret-12345';
        const encrypted = service.encrypt(plaintext);
        const decrypted = service.decrypt(encrypted);

        expect(decrypted).toBe(plaintext);
      });

      it('should decrypt empty string', () => {
        const plaintext = '';
        const encrypted = service.encrypt(plaintext);
        const decrypted = service.decrypt(encrypted);

        expect(decrypted).toBe(plaintext);
      });

      it('should decrypt long strings', () => {
        const plaintext = 'a'.repeat(1000);
        const encrypted = service.encrypt(plaintext);
        const decrypted = service.decrypt(encrypted);

        expect(decrypted).toBe(plaintext);
      });

      it('should throw error for invalid format (missing parts)', () => {
        const invalidCiphertext = 'abc123';

        expect(() => service.decrypt(invalidCiphertext)).toThrow();
      });

      it('should throw error for invalid format (too many parts)', () => {
        const invalidCiphertext = 'abc:def:ghi:jkl';

        expect(() => service.decrypt(invalidCiphertext)).toThrow();
      });

      it('should throw error for non-hex IV', () => {
        const invalidCiphertext = 'xyz:ciphertext:authtag';

        expect(() => service.decrypt(invalidCiphertext)).toThrow();
      });

      it('should throw error for invalid auth tag (tampered ciphertext)', () => {
        const plaintext = 'my-secret-abc-123-xyz-789';
        const encrypted = service.encrypt(plaintext);

        const parts = encrypted.split(':');
        const tamperedCiphertext = parts[1]
          .split('')
          .map((c) => {
            if (c === '0') return 'f';
            if (c === 'f') return '0';
            return String.fromCharCode(c.charCodeAt(0) + 1);
          })
          .join('');
        const tampered = `${parts[0]}:${tamperedCiphertext}:${parts[2]}`;

        expect(() => service.decrypt(tampered)).toThrow();
      });

      it('should throw error for wrong auth tag', () => {
        const plaintext = 'my-secret';
        const encrypted = service.encrypt(plaintext);

        // Replace auth tag with different value
        const parts = encrypted.split(':');
        const wrongAuthTag = '0'.repeat(32);
        const tampered = `${parts[0]}:${parts[1]}:${wrongAuthTag}`;

        expect(() => service.decrypt(tampered)).toThrow();
      });
    });

    describe('encrypt/decrypt roundtrip', () => {
      it('should handle multiple encrypt/decrypt cycles', () => {
        const testCases = [
          'simple-secret',
          'secret-with-special-chars!@#$%^&*()',
          'unicode-secret-密码-🔐',
          '  spaces  ',
          '1234567890',
        ];

        testCases.forEach((plaintext) => {
          const encrypted = service.encrypt(plaintext);
          const decrypted = service.decrypt(encrypted);
          expect(decrypted).toBe(plaintext);
        });
      });
    });
  });

  describe('with missing encryption key', () => {
    it('should throw error on module initialization if OAUTH_SECRET_ENCRYPTION_KEY is not set', async () => {
      delete process.env.OAUTH_SECRET_ENCRYPTION_KEY;

      const module: TestingModule = await Test.createTestingModule({
        providers: [OAuthSecretEncryptionService],
      }).compile();

      const service = module.get<OAuthSecretEncryptionService>(OAuthSecretEncryptionService);
      
      expect(() => service.onModuleInit()).toThrow('OAUTH_SECRET_ENCRYPTION_KEY environment variable is not set');
    });
  });
  });

  describe('with invalid encryption key', () => {
    afterEach(() => {
      delete process.env.OAUTH_SECRET_ENCRYPTION_KEY;
    });

    it('should throw error if key is too short (not 32 bytes)', async () => {
      process.env.OAUTH_SECRET_ENCRYPTION_KEY = INVALID_KEY_SHORT;

      const module: TestingModule = await Test.createTestingModule({
        providers: [OAuthSecretEncryptionService],
      }).compile();

      const service = module.get<OAuthSecretEncryptionService>(OAuthSecretEncryptionService);

      expect(() => service.onModuleInit()).toThrow('OAUTH_SECRET_ENCRYPTION_KEY must be a 64-character hex string (32 bytes)');
    });

    it('should throw error if key contains non-hex characters', async () => {
      process.env.OAUTH_SECRET_ENCRYPTION_KEY = INVALID_KEY_NON_HEX;

      const module: TestingModule = await Test.createTestingModule({
        providers: [OAuthSecretEncryptionService],
      }).compile();

      const service = module.get<OAuthSecretEncryptionService>(OAuthSecretEncryptionService);

      expect(() => service.onModuleInit()).toThrow('OAUTH_SECRET_ENCRYPTION_KEY must be a 64-character hex string (32 bytes)');
    });
  });
});
